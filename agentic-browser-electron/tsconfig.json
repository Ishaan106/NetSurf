{
    "compilerOptions": {
        "target": "ES2020",
        "useDefineForClassFields": true,
        "lib": [
            "ES2020",
            "DOM",
            "DOM.Iterable"
        ],
        "module": "ESNext",
        "skipLibCheck": true,
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "jsx": "react-jsx",
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true,
        "paths": {
            "@/*": [
                "./frontend/*"
            ],
            "@components/*": [
                "./frontend/components/*"
            ],
            "@features/*": [
                "./frontend/features/*"
            ],
            "@store/*": [
                "./frontend/store/*"
            ],
            "@hooks/*": [
                "./frontend/hooks/*"
            ],
            "@theme/*": [
                "./frontend/theme/*"
            ],
            "@utils/*": [
                "./frontend/utils/*"
            ]
        }
    },
    "include": [
        "frontend"
    ],
    "references": [
        {
            "path": "./tsconfig.node.json"
        }
    ]
}